# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CQ Pipeline — Environment Configuration (Example)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your values.
# Never commit the actual .env file!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Pipeline Settings ────────────────────────────────────────────
CQ_PIPELINE__LOG_LEVEL=INFO
CQ_PIPELINE__TIMEOUT=120
CQ_PIPELINE__PARALLEL_WORKERS=4

# ─── API Dashboard ───────────────────────────────────────────────
# SQLite (development)
CQ_DATABASE_URL=sqlite+aiosqlite:///./cqpipeline.db

# PostgreSQL (production)
# CQ_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cqpipeline

CQ_DEBUG=false
CQ_API_KEY=change-me-to-a-secure-key
CQ_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Scanner Overrides ───────────────────────────────────────────
# CQ_SCANNERS__SECRETS__ENABLED=true
# CQ_SCANNERS__LINTING__ENABLED=true
# CQ_SCANNERS__SAST__ENABLED=true
# CQ_SCANNERS__DEPENDENCIES__ENABLED=true
# CQ_SCANNERS__QUALITY__ENABLED=true
# CQ_SCANNERS__FILES__ENABLED=true
# CQ_SCANNERS__TYPE_CHECKING__ENABLED=false
